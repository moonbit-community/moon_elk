pub struct WhiteboxTestMethod[T, G] {
  method_name : String
  ignored : Bool
  fail_if_not_executed : Bool
  only_on_root_node : Bool
  before_processor_ids : Array[String]
  after_processor_ids : Array[String]
  run_fn : (T, G) -> Unit
}
pub fn[T, G] WhiteboxTestMethod::get_after_processor_ids(Self[T, G]) -> Array[String]
pub fn[T, G] WhiteboxTestMethod::get_before_processor_ids(Self[T, G]) -> Array[String]
pub fn[T, G] WhiteboxTestMethod::get_fail_if_not_executed(Self[T, G]) -> Bool
pub fn[T, G] WhiteboxTestMethod::get_method_name(Self[T, G]) -> String
pub fn[T, G] WhiteboxTestMethod::get_only_on_root_node(Self[T, G]) -> Bool
pub fn[T, G] WhiteboxTestMethod::invoke(Self[T, G], T, G) -> Unit
pub fn[T, G] WhiteboxTestMethod::is_ignored(Self[T, G]) -> Bool

