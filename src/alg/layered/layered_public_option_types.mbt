///|
/// Keep the historical `@layered` option vocabulary available while the
/// dedicated options package owns the concrete definitions.
///
/// `pub using` preserves type identity and method lookup without maintaining a
/// second set of mirror enums in this facade package.
pub using @options {
  type CenterEdgeLabelPlacementStrategy,
  type ConstraintCalculationStrategy,
  type CrossingMinimizationStrategy,
  type CuttingStrategy,
  type CycleBreakingStrategy,
  type DirectionCongruency,
  type EdgeConstraint,
  type EdgeLabelSideSelection,
  type EdgeStraighteningStrategy,
  type FixedAlignment,
  type GraphCompactionStrategy,
  type GraphProperties,
  type GreedySwitchType,
  type GroupOrderStrategy,
  type InLayerConstraint,
  type InteractiveReferencePoint,
  type LayerConstraint,
  type LayerUnzippingStrategy,
  type LayeringStrategy,
  type LongEdgeOrderingStrategy,
  type NodeFlexibility,
  type NodePlacementStrategy,
  type NodePromotionStrategy,
  type OrderingStrategy,
  type PortSortingStrategy,
  type PortType,
  type SelfLoopDistributionStrategy,
  type SelfLoopOrderingStrategy,
  type SelfLoopPlacementStrategy,
  type ValidifyStrategy,
  type WrappingStrategy,
  center_edge_label_placement_strategy_uses_label_size_information_values,
  crossing_minimization_strategy_to_string,
  crossing_minimization_strategy_values,
  cycle_breaking_strategy_to_string,
  cycle_breaking_strategy_values,
  edge_label_side_selection_to_string,
  edge_label_side_selection_transpose_values,
  graph_properties_to_string,
  graph_properties_values,
  greedy_switch_type_values,
  group_order_strategy_equals,
  group_order_strategy_from_string,
  group_order_strategy_to_string,
  group_order_strategy_values,
  interactive_reference_point_to_string,
  interactive_reference_point_values,
  layer_constraint_from_string,
  layer_constraint_is_first_or_last_separate,
  layer_constraint_to_string,
  layer_constraint_values,
  layering_strategy_to_string,
  layering_strategy_values,
  long_edge_ordering_strategy_return_values,
  node_flexibility_flags,
  node_flexibility_is_at_least_values,
  node_placement_strategy_to_string,
  node_placement_strategy_values,
  port_type_values,
}
